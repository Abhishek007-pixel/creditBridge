# ── LLM Provider (set ONE of these) ──────────────────────────────────────
# Gemini (free at aistudio.google.com):
GEMINI_API_KEY=

# Mistral (free tier at console.mistral.ai):
MISTRAL_API_KEY=

# OpenAI:
OPENAI_API_KEY=

# ── Which model to use ────────────────────────────────────────────────────
# Gemini:  gemini/gemini-2.0-flash
# Mistral: mistral/mistral-medium-latest
# OpenAI:  openai/gpt-4o-mini
AGENT_MODEL_NAME=gemini/gemini-2.0-flash

# ── Backend config ────────────────────────────────────────────────────────
SECRET_KEY=creditbridge-secret-key-change-in-production-min-32-chars
DATABASE_URL=./creditbridge.db
DEBUG=true

# ── Neuro SAN config ──────────────────────────────────────────────────────
# For ns run (studio):  registries/manifest.hocon
# For direct session:   agents/registries/manifest.hocon
AGENT_MANIFEST_FILE=registries/manifest.hocon
AGENT_TOOL_PATH=.

# ── Feature flags ─────────────────────────────────────────────────────────
# true  = run real Neuro SAN agent pipeline
# false = use synthetic scoring only (always works, no API key needed)
USE_AGENTS=true
